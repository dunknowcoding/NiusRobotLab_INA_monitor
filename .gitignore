# Dependencies (never commit)
node_modules/

# TypeScript / project build outputs (precompiled artifacts — rebuild with npm run build)
packages/*/dist/
packages/*/dist-electron/
packages/*/dist-renderer/
dist/
dist-electron/
dist-renderer/

# Vite cache
**/.vite/

# TypeScript incremental build info (project root / packages)
*.tsbuildinfo

# Tests & coverage
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment & secrets
.env
.env.*
!.env.example

# OS junk
.DS_Store
Thumbs.db
Desktop.ini

# IDE / editor
.idea/
*.swp
*.swo
*~

# Caches
.eslintcache
.cache/

# Packaged artifacts
*.vsix
*.tgz

# Electron / installer output (if added later)
release/
out/
