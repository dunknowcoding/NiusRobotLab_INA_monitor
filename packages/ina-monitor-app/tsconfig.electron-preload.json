{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist-electron",
    "rootDir": "electron",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noEmitOnError": true,
    "esModuleInterop": true
  },
  "include": ["electron/preload.ts"]
}
