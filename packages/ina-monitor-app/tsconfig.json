{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*", "tool/**/*", "vite.config.ts"]
}

