{
  "name": "@niusrobotlab/ina-monitor-app",
  "version": "0.1.5",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "predev": "npm run build:electron",
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && tsc -p tsconfig.electron-preload.json",
    "start:prod": "cross-env NODE_ENV=production electron .",
    "lint": "eslint .",
    "format": "prettier -w ."
  },
  "dependencies": {
    "@niusrobotlab/ina-monitor-core": "0.1.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serialport": "^13.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^32.2.1",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "wait-on": "^8.0.2",
    "cross-env": "^7.0.3"
  }
}
